rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the caller is an authenticated admin
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Products & Collections: Anyone can read, only admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /collections/{collectionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Inquiries: Anyone can create (analytics click logging), nobody can read/update/delete except admin
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
